# ── Repo ──────────────────────────────────────────────────────────────────────
# Path to the git repository the agent should improve
REPO_PATH=/path/to/your/repo

# Entry point for the build smoke test — must be the REAL build tool,
# not just a type-checker (tsc --noEmit misses import resolution errors).
# Examples:
#   bun build src/main.ts --target=bun --outfile=/dev/null
#   npm run build -- --dry-run
#   cargo check
BUILD_CMD="bun build src/main.ts --target=bun --outfile=/dev/null"

# ── LLM ───────────────────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=sk-YOUR_KEY_HERE

# Model used for drafting code changes (needs tool/code-writing capability)
DRAFT_MODEL=gpt-4o

# Model used for applicability review (can be smaller/cheaper)
REVIEW_MODEL=gpt-4o-mini

# Models used for memory consolidation + verification pass
CONSOLIDATE_MODEL=gpt-4o-mini
VERIFY_MODEL=gpt-4o-mini

# ── Paths ─────────────────────────────────────────────────────────────────────
# Staging area for proposals (should be OUTSIDE the repo)
STAGING_DIR=/tmp/agent-si-staging

# Agent memory file (plain text, one observation per line)
MEMORY_FILE=/path/to/your/agent/observations.md

# Log file
LOG_FILE=/tmp/agent-si.log

# ── Signal sources ────────────────────────────────────────────────────────────
# Upstream GitHub repos to watch for improvements (comma-separated owner/repo)
WATCH_REPOS=org/repo-a,org/repo-b

# Path to your agent's error/runtime log (gathered as signals too)
AGENT_ERROR_LOG=/path/to/your/agent/error.log

# ── Process management ────────────────────────────────────────────────────────
# Command to restart your agent after a successful merge
# Leave blank to skip restart (e.g. if your agent hot-reloads)
RESTART_CMD="systemctl --user restart myagent.service"

# Seconds the service must stay alive post-restart to be considered healthy
HEALTH_WINDOW=20

# ── Notifications (optional) ──────────────────────────────────────────────────
# Shell command that accepts a single string argument (the notification message).
# Leave blank to disable notifications.
# Examples:
#   NOTIFY_CMD="curl -s -X POST https://hooks.slack.com/... -d '{\"text\":\"$1\"}'"
#   NOTIFY_CMD="./scripts/notify.sh"
NOTIFY_CMD=""

# ── Loop behaviour ────────────────────────────────────────────────────────────
# Max number of proposals to draft per run (prevents runaway LLM spend)
MAX_PER_RUN=2

# Autonomous mode:
#   0 = human must approve each proposal before merge (default, recommended)
#   1 = guardian-protected auto-merge (memory + service guardians roll back on failure)
AUTONOMOUS=0

# Dry run:
#   1 = apply + smoke + rollback only — never commit, restart, or notify
#   0 = normal operation
DRY_RUN=0
